# ── Docker / PostgreSQL (docker-compose.yml) ──────────────────
POSTGRES_DB=bunyang_flow
POSTGRES_USER=bunyang
POSTGRES_PASSWORD=bunyang
POSTGRES_PORT=5432

# ── Frontend (Vite, envDir: "../../") ─────────────────────────
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
VITE_API_BASE_URL=http://localhost:4000
VITE_KAKAO_MAP_KEY=your_kakao_javascript_app_key
