# 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_CLIENT_ID=your_kakao_rest_api_key

# 카카오 개발자 콘솔 > 보안 > Client Secret
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# 카카오 개발자 콘솔 > 플랫폼 > Redirect URI에 등록된 값과 일치해야 함
KAKAO_CALLBACK_URL=http://localhost:4000/auth/kakao/callback

# JWT 서명 비밀키 (임의의 긴 랜덤 문자열 권장)
JWT_SECRET=change-me-to-a-random-secret

# 프론트엔드 URL (카카오 콜백 후 리디렉트 대상)
FRONTEND_URL=http://localhost:5173

# API 서버 포트
API_PORT=4000
