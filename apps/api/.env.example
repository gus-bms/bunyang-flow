# ── Server ────────────────────────────────────────────────────
API_PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Database (Prisma) ─────────────────────────────────────────
DATABASE_URL="postgresql://bunyang:bunyang@localhost:5432/bunyang_flow?schema=public"

# ── Auth ──────────────────────────────────────────────────────
# 임의의 긴 랜덤 문자열 (예: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# ── Kakao (developers.kakao.com) ──────────────────────────────
# 내 애플리케이션 > 앱 키 > REST API 키
# (Kakao SSO 로그인 + 주소→좌표 변환(Kakao Local API) 양쪽에 사용됨)
KAKAO_CLIENT_ID=your_kakao_rest_api_key
# 내 애플리케이션 > 보안 > Client Secret
KAKAO_CLIENT_SECRET=your_kakao_client_secret
# 내 애플리케이션 > 플랫폼 > Redirect URI 에 동일하게 등록
KAKAO_CALLBACK_URL=http://localhost:4000/auth/kakao/callback

# ── 공공데이터포털 (data.go.kr) ────────────────────────────────
# "청약홈 분양정보 조회 서비스" 활용 신청 후 발급
PUBLIC_DATA_API_KEY=your_public_data_api_key

# ── Redis (선택 — 없으면 메모리 캐시로 동작) ──────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Web Push / VAPID (web-push 패키지로 생성: npx web-push generate-vapid-keys) ──
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@your-domain.com
